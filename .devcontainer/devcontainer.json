{
  "name": "Python 3 + Node",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.11-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {}
  },
  "customizations": {
    "codespaces": {
      "openFiles": [
        "README.md",
        "api/main.py",
        "web/app/rankings/page.tsx"
      ]
    },
    "vscode": {
      "settings": {},
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    }
  },
  "updateContentCommand": "[ -f requirements.txt ] && pip3 install --user -r requirements.txt; (cd web && npm install); echo '✅ Packages installed'",
  "postAttachCommand": {
    "api": "uvicorn api.main:app --reload --host 0.0.0.0 --port 8000",
    "web": "cd web && npm run dev"
  },
  "portsAttributes": {
    "8000": {
      "label": "API",
      "onAutoForward": "notify"
    },
    "3000": {
      "label": "Web App",
      "onAutoForward": "openPreview"
    }
  },
  "forwardPorts": [
    8000,
    3000
  ]
}
